# Chave de segurança para tokens (Mude em produção)
JWT_SECRET=sua_chave_secreta_jwt

# Credenciais de Servidor SMTP (Recuperação de Senha)
SMTP_HOST=smtp.servidor.com
SMTP_PORT=465
SMTP_USER=seu_email@dominio.com
SMTP_PASS=senha_de_aplicativo

# URL base do Frontend (usada para gerar links de e-mail e CORS)
FRONTEND_URL=http://localhost:5173

# Mercado Pago (Integração de Pagamento)
# Substitua as chaves abaixo pelas fornecidas pelo painel do Mercado Pago
MP_ACCESS_TOKEN=APP_USR-00000000000-000000-00000000000000000000
MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000
